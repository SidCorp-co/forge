#!/bin/bash
# pre-push hook — Trunk-Based Development discipline.
#
# Runs build + tests on the pnpm workspace packages that have files changed
# in the commits being pushed. Aborts the push on any failure so main stays
# green.
#
# Skip mechanisms (use sparingly):
#   - PREPUSH_SKIP_TESTS=1        — build only, no tests (faster, less safe)
#   - git push --no-verify        — git-native bypass for emergency reverts only

set -e

# Capture stdin once — git only writes the ref list to the hook's stdin once,
# so subsequent loops have to read from a saved copy.
stdin_input="$(cat)"

# Branch name validation per ADR 0014. Cheap; runs before the expensive
# build/test cycle so a bad name fails fast.
repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -x "$repo_root/scripts/check-branch-name.sh" ]; then
  while read -r local_ref _ _ _; do
    case "$local_ref" in
      refs/heads/*)
        local_branch="${local_ref#refs/heads/}"
        if ! "$repo_root/scripts/check-branch-name.sh" "$local_branch"; then
          echo "[pre-push] FAIL: branch name violates ADR 0014. Push aborted."
          echo "[pre-push] Rename the branch to match an accepted pattern."
          exit 1
        fi
        ;;
    esac
  done <<< "$stdin_input"
fi

# Read pushed refs from the captured stdin (format:
# <local-ref> <local-sha> <remote-ref> <remote-sha>)
range=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    # Branch deletion — nothing to validate
    continue
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — diff against main as the merge-base reference
    base=$(git merge-base "$local_sha" main 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      range="$range $base..$local_sha"
    else
      # No merge-base (truly fresh) — diff entire branch
      range="$range $local_sha"
    fi
  else
    range="$range $remote_sha..$local_sha"
  fi
done <<< "$stdin_input"

if [ -z "$range" ]; then
  echo "[pre-push] no commits to validate"
  exit 0
fi

# Collect changed files across all push ranges
changed=$(git diff --name-only $range 2>/dev/null | sort -u)

if [ -z "$changed" ]; then
  echo "[pre-push] no file changes in pushed commits"
  exit 0
fi

# Map changed files to affected packages
packages=""
echo "$changed" | grep -q '^packages/core/' && packages="$packages core"
echo "$changed" | grep -q '^packages/web/' && packages="$packages web"
echo "$changed" | grep -q '^packages/dev/' && packages="$packages dev"
echo "$changed" | grep -q '^packages/widget/' && packages="$packages widget"
echo "$changed" | grep -q '^packages/contracts/' && packages="$packages contracts"

if [ -z "$packages" ]; then
  echo "[pre-push] no source-package files changed (docs/skills/etc only) — skipping build/test"
  exit 0
fi

# Guard: tauri.conf.json bundle.active must stay true. Without it `tauri build`
# emits only the raw binary — release.yml's tauri-action then fails with
# "No artifacts were found." (every release v0.1.9..v0.1.16 hit this silently.)
repo_root=$(git rev-parse --show-toplevel)
tauri_conf="$repo_root/packages/dev/src-tauri/tauri.conf.json"
if [ -f "$tauri_conf" ] && command -v jq >/dev/null 2>&1; then
  if ! jq -e '.bundle.active == true' "$tauri_conf" >/dev/null; then
    echo "[pre-push] FAIL: packages/dev/src-tauri/tauri.conf.json must have bundle.active=true."
    echo "[pre-push] Without it, release builds skip bundling and produce zero installer artifacts."
    exit 1
  fi
fi

echo "[pre-push] validating packages:$packages"

repo_root=$(git rev-parse --show-toplevel)
for pkg in $packages; do
  pkg_dir="$repo_root/packages/$pkg"
  if [ ! -d "$pkg_dir" ]; then
    echo "[pre-push] skip $pkg — directory missing"
    continue
  fi
  echo "[pre-push] $pkg → pnpm build"
  (cd "$pkg_dir" && pnpm build) || {
    echo "[pre-push] FAIL: $pkg build broke. Push aborted."
    exit 1
  }
  if [ "$PREPUSH_SKIP_TESTS" = "1" ]; then
    echo "[pre-push] $pkg → tests skipped (PREPUSH_SKIP_TESTS=1)"
    continue
  fi
  # `dev` and `contracts` may not have a meaningful test command — skip if absent
  if (cd "$pkg_dir" && grep -q '"test":' package.json); then
    echo "[pre-push] $pkg → pnpm test"
    (cd "$pkg_dir" && pnpm test) || {
      echo "[pre-push] FAIL: $pkg tests broke. Push aborted."
      exit 1
    }
  else
    echo "[pre-push] $pkg → no test script, skipping"
  fi
done

echo "[pre-push] all checks passed for:$packages"
exit 0
