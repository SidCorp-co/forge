#!/bin/bash
# pre-push hook — cheap guards only. CI (`ci-passed` aggregate check) is the
# AUTHORITATIVE merge gate; this hook just catches obvious mistakes fast and
# stays out of the way.
#
# Default behavior:
#   - branch-name check (ADR 0014)  → WARN only, never blocks
#   - tauri bundle.active guard     → hard FAIL (silently kills release artifacts)
#   - package builds/tests          → SKIPPED
#
# Controls:
#   PREPUSH_BUILD=1 git push   — also build affected packages
#   PREPUSH_FULL=1  git push   — build + run affected packages' test suites
#   SKIP_PREPUSH=1  git push   — skip everything

set -e

if [ "$SKIP_PREPUSH" = "1" ]; then
  echo "[pre-push] SKIP_PREPUSH=1 — skipping all checks"
  exit 0
fi

# Capture stdin once — git only writes the ref list to the hook's stdin once.
stdin_input="$(cat)"
repo_root=$(git rev-parse --show-toplevel 2>/dev/null)

# Branch name per ADR 0014 — advisory. The pipeline generates compliant names
# itself and CI gates the merge, so a human/owner push is never blocked on
# naming.
if [ -x "$repo_root/scripts/check-branch-name.sh" ]; then
  while read -r local_ref _ _ _; do
    case "$local_ref" in
      refs/heads/*)
        branch="${local_ref#refs/heads/}"
        if ! "$repo_root/scripts/check-branch-name.sh" "$branch" >/dev/null 2>&1; then
          echo "[pre-push] WARN: branch '$branch' violates ADR 0014 naming — push continues (pipeline-tracked branches need ISS-<seq>-<slug>)"
        fi
        ;;
    esac
  done <<< "$stdin_input"
fi

# Guard: tauri.conf.json bundle.active must stay true. Without it `tauri build`
# emits only the raw binary — release.yml's tauri-action then fails with
# "No artifacts were found." (every release v0.1.9..v0.1.16 hit this silently.)
tauri_conf="$repo_root/packages/dev/src-tauri/tauri.conf.json"
if [ -f "$tauri_conf" ] && command -v jq >/dev/null 2>&1; then
  if ! jq -e '.bundle.active == true' "$tauri_conf" >/dev/null; then
    echo "[pre-push] FAIL: packages/dev/src-tauri/tauri.conf.json must have bundle.active=true."
    echo "[pre-push] Without it, release builds skip bundling and produce zero installer artifacts."
    exit 1
  fi
fi

if [ "$PREPUSH_BUILD" != "1" ] && [ "$PREPUSH_FULL" != "1" ]; then
  echo "[pre-push] cheap guards passed — builds/tests skipped (CI gates; PREPUSH_BUILD=1 / PREPUSH_FULL=1 to run locally)"
  exit 0
fi

# ---- opt-in build/test path ------------------------------------------------

# Read pushed refs from the captured stdin (format:
# <local-ref> <local-sha> <remote-ref> <remote-sha>)
range=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue # branch deletion
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base=$(git merge-base "$local_sha" main 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      range="$range $base..$local_sha"
    else
      range="$range $local_sha"
    fi
  else
    range="$range $remote_sha..$local_sha"
  fi
done <<< "$stdin_input"

if [ -z "$range" ]; then
  echo "[pre-push] no commits to validate"
  exit 0
fi

changed=$(git diff --name-only $range 2>/dev/null | sort -u)

if [ -z "$changed" ]; then
  echo "[pre-push] no file changes in pushed commits"
  exit 0
fi

packages=""
echo "$changed" | grep -q '^packages/core/' && packages="$packages core"
echo "$changed" | grep -q '^packages/web-v2/' && packages="$packages web-v2"
echo "$changed" | grep -q '^packages/dev/' && packages="$packages dev"
echo "$changed" | grep -q '^packages/contracts/' && packages="$packages contracts"

if [ -z "$packages" ]; then
  echo "[pre-push] no source-package files changed — nothing to build"
  exit 0
fi

echo "[pre-push] validating packages:$packages"

for pkg in $packages; do
  pkg_dir="$repo_root/packages/$pkg"
  if [ ! -d "$pkg_dir" ]; then
    echo "[pre-push] skip $pkg — directory missing"
    continue
  fi
  echo "[pre-push] $pkg → pnpm build (with workspace deps prebuilt)"
  # Emit-only workspace deps (e.g. @forge/observability → dist/) must build
  # before any consumer, or the consumer's import resolves to a missing file.
  if [ -d "$repo_root/packages/observability" ]; then
    (cd "$repo_root" && pnpm --filter @forge/observability build) || {
      echo "[pre-push] FAIL: @forge/observability build broke (consumer of $pkg)."
      exit 1
    }
  fi
  (cd "$pkg_dir" && pnpm build) || {
    echo "[pre-push] FAIL: $pkg build broke. Push aborted."
    exit 1
  }
  if [ "$PREPUSH_FULL" != "1" ]; then
    continue
  fi
  if (cd "$pkg_dir" && grep -q '"test":' package.json); then
    echo "[pre-push] $pkg → pnpm test"
    (cd "$pkg_dir" && pnpm test) || {
      echo "[pre-push] FAIL: $pkg tests broke. Push aborted."
      exit 1
    }
  else
    echo "[pre-push] $pkg → no test script, skipping"
  fi
done

echo "[pre-push] all checks passed for:$packages"
exit 0
