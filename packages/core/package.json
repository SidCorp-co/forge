{
  "name": "@forge/core",
  "version": "0.3.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Forge core API — Hono + Drizzle (RFC 0002 Strapi replacement).",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./public": {
      "types": "./src/public.ts",
      "default": "./dist/public.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "drizzle",
    "public"
  ],
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:ci": "TEST_DB_MODE=container vitest run --config vitest.integration.config.ts",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@forge/observability": "workspace:*",
    "@google/genai": "^2.11.0",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sentry/node": "^10.65.0",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "@zxcvbn-ts/language-en": "^4.1.1",
    "argon2": "^0.44.0",
    "cron-parser": "^5.6.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@forge/contracts": "workspace:*",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
