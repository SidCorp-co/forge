{
  "name": "@forge/contracts",
  "version": "0.2.4",
  "private": true,
  "license": "Apache-2.0",
  "description": "Shared TypeScript types + request schemas derived from @forge/core (Drizzle rows + Zod schemas). Type-only surface — no runtime coupling.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pipeline-registry": {
      "types": "./src/pipeline-registry.ts",
      "default": "./src/pipeline-registry.ts"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "dependencies": {
    "@forge/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json"
  }
}
