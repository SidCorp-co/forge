{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge Beta",
  "mainBinaryName": "forge-beta",
  "version": "0.1.33",
  "identifier": "co.sidcorp.forge-beta",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Forge Beta — stg",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "app", "dmg", "nsis"],
    "publisher": "SidCorp",
    "category": "DeveloperTool",
    "shortDescription": "Remote-control your local Claude Code",
    "copyright": "Copyright 2026 SidCorp",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/icon.png"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["forge-beta"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNFNDI2M0JFRUVCRURCQTQKUldTazI3N3V2bU5DUG9QUTk1ZGEwVTQxNFNVZkZhdjE0YXU3MEwwcS9RMWprVzJtNlRnSXpnU3UK",
      "endpoints": [
        "https://github.com/SidCorp-co/forge/releases/latest/download/latest.json"
      ]
    }
  }
}
