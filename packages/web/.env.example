# Public origin of this web app. Used for canonical links + OpenGraph/Twitter
# metadata on the /download page. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# packages/core base URL (must end in /api).
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Optional explicit WS URL. Defaults to the API URL with /api stripped and
# http(s):// replaced with ws(s):// + /ws.
# NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Optional Spline 3D scene URL for the landing hero. Falls back to the
# bundled scene if unset.
# NEXT_PUBLIC_SPLINE_SCENE_URL=

# Optional "Book a demo" CTA target on the landing page. Defaults to the
# in-page "#book" anchor if unset.
# NEXT_PUBLIC_BOOKING_URL=

# Optional environment-banner label shown in the UI chrome (e.g. STAGING,
# PREVIEW). Empty / unset hides the banner.
# NEXT_PUBLIC_ENV_LABEL=
