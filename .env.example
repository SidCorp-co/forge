# Database
POSTGRES_PASSWORD=forge_secret

# Core API (packages/core) — required
# Generate strong values: openssl rand -base64 32
JWT_SECRET=
DEVICE_TOKEN_PEPPER=
CORS_ORIGINS=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Core API — SMTP (required by core env schema; leave blank for dev if unused)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Scripts & dev tooling
# FORGE_API_KEY: project-scoped key sent as X-Forge-API-Key header
FORGE_API_KEY=

# AI / embeddings (optional)
LITELLM_API_URL=
LITELLM_API_KEY=
LITELLM_MODEL=

# Optional Sentry telemetry (opt-in). Empty = SDK no-op (no events sent).
# Two distinct DSNs because docker-compose interpolation can't pass per-
# service overrides via a single SENTRY_DSN var — core needs the forge-
# core project, web needs the forge-web project.
#   - SENTRY_DSN_CORE: Hono backend (5xx + unhandled errors)
#   - SENTRY_DSN_WEB:  Next.js client (browser errors) AND server (SSR
#                      errors via onRequestError); same DSN both surfaces.
SENTRY_DSN_CORE=
SENTRY_DSN_WEB=

# ISS-234 — AES-256-GCM master key for the integration framework's
# CredentialVault. Generate with: openssl rand -base64 32
# Optional. The vault refuses to boot if this is missing AND any active row
# exists in project_integrations; fresh installs without integrations stay
# bootable without it.
INTEGRATION_MASTER_KEY=
