# Database
POSTGRES_PASSWORD=forge_secret

# Strapi secrets (generate with: openssl rand -base64 32)
APP_KEYS=key1,key2
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# Web
NEXT_PUBLIC_API_URL=http://localhost:1337/api

# Scripts & dev tooling
# STRAPI_URL: where dev scripts hit Strapi (default: http://localhost:1337/api)
STRAPI_URL=http://localhost:1337/api
# STRAPI_TOKEN: Strapi API token — generate at /admin → Settings → API Tokens
STRAPI_TOKEN=
# FORGE_API_KEY: project-scoped key sent as X-Forge-API-Key header
FORGE_API_KEY=

# AI (optional)
LITELLM_API_URL=
LITELLM_API_KEY=
LITELLM_MODEL=
