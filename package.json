{
  "name": "forge",
  "version": "0.3.0",
  "private": true,
  "description": "Open-source control plane for Claude Code. Monorepo root.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "turbo": "^2.10.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "postcss": ">=8.5.10",
      "qs": ">=6.15.2",
      "undici": ">=7.28.0 <8",
      "protobufjs": ">=7.6.3 <8",
      "@protobufjs/utf8": ">=1.1.1 <2",
      "@grpc/grpc-js": ">=1.14.4 <2",
      "vite": ">=6.4.3 <7",
      "lodash": ">=4.18.0 <5",
      "tmp": ">=0.2.6 <0.3",
      "fast-uri": ">=3.1.2 <4",
      "uuid": ">=11.1.1 <12",
      "hono": ">=4.12.25 <5",
      "@opentelemetry/core": ">=2.8.0 <3",
      "ip-address": ">=10.1.1 <11",
      "@babel/core": ">=7.29.6 <8",
      "esbuild": ">=0.25.0 <0.28.0 || >=0.28.1"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
