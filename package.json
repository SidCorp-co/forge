{
  "name": "forge",
  "version": "0.2.12",
  "private": true,
  "description": "Open-source control plane for Claude Code. Monorepo root.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "postcss": ">=8.5.10",
      "qs": ">=6.15.2"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
