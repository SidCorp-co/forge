# Strapi and some plugins expect flat node_modules — hoist to avoid
# "Cannot find module" issues at runtime.
node-linker=hoisted
shamefully-hoist=true

# Auto-install peer dependencies (reduces friction during OSS contributor setup).
auto-install-peers=true

# Use the on-disk content-addressable store efficiently.
prefer-workspace-packages=true

# Fail fast on engines mismatch (we require Node >=20).
engine-strict=true
