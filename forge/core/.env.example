# Postgres connection string used by Drizzle ORM, pg-boss, and pgvector.
# Point at the same Postgres instance used by Strapi for now.
# Format: postgres://user:password@host:port/dbname
# pg-boss will create and manage its own pgboss.* schema in this database on first start.
DATABASE_URL=postgres://forge:forge@localhost:5432/forge

# Auth secrets — minimum 32 chars each. Generate via: openssl rand -hex 32
JWT_SECRET=
DEVICE_TOKEN_PEPPER=

# SMTP (outbound email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
# When true, outbound emails are skipped and the verification link is logged to
# stdout. Use for local dev so you can click the link without a real SMTP account.
SMTP_DEBUG=false

# Base URL used to build outbound links (e.g. verification email link).
# In Phase 2 this points at the core backend origin; GET /api/auth/verify lives there.
APP_BASE_URL=http://localhost:8080

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:1420

# HTTP port for the Hono server (optional, defaults to 8080)
PORT=8080

# development | test | production (optional, defaults to development)
NODE_ENV=development
