# Postgres connection string used by Drizzle ORM, pg-boss, and pgvector.
# Point at the same Postgres instance used by Strapi for now.
# Format: postgres://user:password@host:port/dbname
# pg-boss will create and manage its own pgboss.* schema in this database on first start.
DATABASE_URL=postgres://forge:forge@localhost:5432/forge

# Auth secrets — minimum 32 chars each. Generate via: openssl rand -hex 32
JWT_SECRET=
DEVICE_TOKEN_PEPPER=

# SMTP (outbound email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
# When true, outbound emails are skipped and the verification link is logged to
# stdout. Use for local dev so you can click the link without a real SMTP account.
SMTP_DEBUG=false

# Base URL used to build outbound links (e.g. verification email link).
# In Phase 2 this points at the core backend origin; GET /api/auth/verify lives there.
APP_BASE_URL=http://localhost:8080

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:1420

# HTTP port for the Hono server (optional, defaults to 8080)
PORT=8080

# development | test | production (optional, defaults to development)
NODE_ENV=development

# Embeddings service (Phase 2.5-F3, memory-knowledge module).
# Points at a LiteLLM-compatible /embeddings endpoint. Leave blank in local
# dev if you don't exercise semantic search — the embeddings singleton is
# lazy and only errors on first use.
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIM=1536
# EMBEDDINGS_FALLBACK_MODEL=
# EMBEDDINGS_TIMEOUT_MS=10000

# OAuth/OIDC providers (ISS-314).
# Toggle the social-auth feature; provider rows are read at request time.
FEATURE_SOCIAL_AUTH=false
# GitHub OAuth App: https://github.com/settings/developers
# Set callback to ${OAUTH_REDIRECT_BASE}/api/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Google OAuth client (Web): https://console.cloud.google.com/apis/credentials
# Set redirect to ${OAUTH_REDIRECT_BASE}/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Generic OIDC (optional) — discovery URL must serve OpenID configuration.
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# Origin used to build the redirect URI sent to providers.
OAUTH_REDIRECT_BASE=http://localhost:8080
