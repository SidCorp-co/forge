{
  "name": "@forge/core",
  "version": "0.0.1",
  "private": true,
  "description": "Forge core API — Hono + Drizzle (RFC 0002 Strapi replacement).",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./public": {
      "types": "./src/public.ts",
      "default": "./dist/public.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "drizzle"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:ci": "TEST_DB_MODE=container vitest run --config vitest.integration.config.ts",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "argon2": "^0.44.0",
    "cron-parser": "^4.9.0",
    "@google/genai": "^0.7.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "jose": "^6.2.2",
    "nodemailer": "^8.0.5",
    "pg-boss": "^10.1.5",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "ws": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
