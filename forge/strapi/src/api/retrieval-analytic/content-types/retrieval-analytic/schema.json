{
  "kind": "collectionType",
  "collectionName": "retrieval_analytics",
  "info": {
    "singularName": "retrieval-analytic",
    "pluralName": "retrieval-analytics",
    "displayName": "RetrievalAnalytic"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "strategy": {
      "type": "enumeration",
      "enum": ["semantic", "keyword", "graph", "hybrid", "auto"],
      "required": true
    },
    "resolvedStrategy": {
      "type": "string"
    },
    "query": {
      "type": "text",
      "required": true
    },
    "resultCount": {
      "type": "integer",
      "default": 0
    },
    "topScore": {
      "type": "float",
      "default": 0
    },
    "latencyMs": {
      "type": "integer",
      "default": 0
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    }
  }
}
