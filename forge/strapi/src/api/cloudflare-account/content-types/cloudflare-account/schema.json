{
  "kind": "collectionType",
  "collectionName": "cloudflare_accounts",
  "info": {
    "singularName": "cloudflare-account",
    "pluralName": "cloudflare-accounts",
    "displayName": "CloudflareAccount"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "accountId": {
      "type": "string",
      "required": true
    },
    "apiToken": {
      "type": "string",
      "private": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive", "error"],
      "default": "active"
    },
    "lastValidated": {
      "type": "datetime"
    },
    "validationError": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
