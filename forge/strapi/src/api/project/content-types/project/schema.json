{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "apiKey": {
      "type": "string"
    },
    "defaultProvider": {
      "type": "enumeration",
      "enum": ["anthropic", "openai", "gemini"],
      "default": "anthropic"
    },
    "issues": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::issue.issue",
      "mappedBy": "project"
    },
    "tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::task.task",
      "mappedBy": "project"
    },
    "chatSessions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::chat-session.chat-session",
      "mappedBy": "project"
    },
    "agentPrompt": {
      "type": "text"
    },
    "agentProvider": {
      "type": "enumeration",
      "enum": ["anthropic", "openai", "gemini"],
      "default": "gemini"
    },
    "agentMemoryEnabled": {
      "type": "boolean",
      "default": true
    },
    "knowledgeIndex": {
      "type": "json"
    },
    "knowledgeIndexedAt": {
      "type": "datetime"
    },
    "conventions": {
      "type": "text"
    },
    "repos": {
      "type": "json",
      "default": []
    },
    "coolifyResources": {
      "type": "json",
      "default": []
    },
    "webhookUrl": {
      "type": "string"
    },
    "webhookSecret": {
      "type": "string",
      "private": true
    },
    "webhookStatuses": {
      "type": "json",
      "default": []
    },
    "rollingStats": {
      "type": "json"
    },
    "sentryProject": {
      "type": "string"
    },
    "agents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::agent.agent",
      "mappedBy": "project"
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "members": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "mcpServers": {
      "type": "json",
      "default": {}
    },
    "mcpLastSyncAt": {
      "type": "datetime"
    },
    "agentConfig": {
      "type": "json"
    },
    "antigravityProjectId": {
      "type": "string"
    },
    "antigravityRunners": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::antigravity-runner.antigravity-runner"
    },
    "defaultAntigravityRunner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::antigravity-runner.antigravity-runner"
    },
    "antigravityProjectMap": {
      "type": "json",
      "default": {}
    },
    "repoPath": {
      "type": "string"
    },
    "baseBranch": {
      "type": "string",
      "default": "main"
    },
    "productionBranch": {
      "type": "string"
    },
    "previewDeploy": {
      "type": "json"
    },
    "defaultDevice": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::device.device"
    },
    "devices": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::device.device"
    },
    "labels": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::label.label",
      "mappedBy": "project"
    },
    "pipelineConfig": {
      "type": "json"
    },
    "skillsSyncedAt": {
      "type": "datetime"
    },
    "projectMeta": {
      "type": "json",
      "default": {}
    },
    "crossProjectAccess": {
      "type": "boolean",
      "default": false
    },
    "heartbeatConfig": {
      "type": "json",
      "default": {}
    },
    "channels": {
      "type": "json",
      "default": []
    }
  }
}
