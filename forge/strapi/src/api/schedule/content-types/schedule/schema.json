{
  "kind": "collectionType",
  "collectionName": "schedules",
  "info": {
    "singularName": "schedule",
    "pluralName": "schedules",
    "displayName": "Schedule"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "cron": {
      "type": "string",
      "required": true
    },
    "prompt": {
      "type": "text",
      "required": true
    },
    "runner": {
      "type": "enumeration",
      "enum": ["desktop", "antigravity"],
      "default": "antigravity"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "targetProjectSlug": {
      "type": "string"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    },
    "lastRunAt": {
      "type": "datetime"
    },
    "nextRunAt": {
      "type": "datetime"
    },
    "lastStatus": {
      "type": "enumeration",
      "enum": ["success", "failed", "running", "skipped"]
    },
    "lastSessionId": {
      "type": "string"
    },
    "metadata": {
      "type": "json"
    }
  }
}
