{
  "kind": "collectionType",
  "collectionName": "user_preferences",
  "info": {
    "singularName": "user-preference",
    "pluralName": "user-preferences",
    "displayName": "UserPreference"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "userKey": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "preferredLanguage": {
      "type": "string"
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "dark", "system"],
      "default": "system"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    }
  }
}
