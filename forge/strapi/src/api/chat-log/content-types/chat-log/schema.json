{
  "kind": "collectionType",
  "collectionName": "chat_logs",
  "info": {
    "singularName": "chat-log",
    "pluralName": "chat-logs",
    "displayName": "ChatLog"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "sessionId": {
      "type": "string",
      "required": true
    },
    "projectSlug": {
      "type": "string",
      "required": true
    },
    "userKey": {
      "type": "string"
    },
    "query": {
      "type": "text",
      "required": true
    },
    "reply": {
      "type": "text"
    },
    "model": {
      "type": "string"
    },
    "ragContext": {
      "type": "json"
    },
    "toolCalls": {
      "type": "json"
    },
    "usage": {
      "type": "json"
    },
    "iterations": {
      "type": "integer",
      "default": 1
    },
    "durationMs": {
      "type": "integer"
    },
    "error": {
      "type": "text"
    },
    "queryIntent": {
      "type": "string"
    },
    "condensedQuery": {
      "type": "text"
    },
    "source": {
      "type": "string",
      "default": "web"
    },
    "qualitySignals": {
      "type": "json"
    },
    "qaRating": {
      "type": "enumeration",
      "enum": ["good", "bad", "flagged"]
    },
    "qaNotes": {
      "type": "text"
    }
  }
}
