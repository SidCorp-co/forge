{
  "kind": "collectionType",
  "collectionName": "knowledge_edges",
  "info": {
    "singularName": "knowledge-edge",
    "pluralName": "knowledge-edges",
    "displayName": "KnowledgeEdge"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "subject": {
      "type": "string",
      "required": true
    },
    "predicate": {
      "type": "string",
      "required": true
    },
    "object": {
      "type": "string",
      "required": true
    },
    "value": {
      "type": "string"
    },
    "sourceMemoryId": {
      "type": "string"
    },
    "confidence": {
      "type": "float",
      "default": 1.0
    },
    "validFrom": {
      "type": "datetime"
    },
    "validUntil": {
      "type": "datetime"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project"
    }
  }
}
