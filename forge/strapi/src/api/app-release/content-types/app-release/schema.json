{
  "kind": "collectionType",
  "collectionName": "app_releases",
  "info": {
    "singularName": "app-release",
    "pluralName": "app-releases",
    "displayName": "App Release"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "version": {
      "type": "string",
      "required": true
    },
    "platform": {
      "type": "enumeration",
      "enum": ["linux-x86_64", "darwin-x86_64", "darwin-aarch64", "windows-x86_64"],
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "signature": {
      "type": "text",
      "required": true
    },
    "binary": {
      "type": "media",
      "allowedTypes": ["files"],
      "required": true
    },
    "isCurrent": {
      "type": "boolean",
      "default": false
    }
  }
}
